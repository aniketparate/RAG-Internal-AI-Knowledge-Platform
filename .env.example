DATABASE_URL=postgresql+asyncpg://rag:rag@postgres:5432/rag_platform
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_COLLECTION=knowledge_base
REDIS_URL=redis://redis:6379/0
GROQ_API_KEY=
XAI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
API_KEY=internal-dev-key
LLM_PROVIDER=groq
LLM_BASE_URL_GROQ=https://api.groq.com/openai/v1
LLM_DEFAULT_MODEL_GROQ=llama-3.3-70b-versatile
LLM_BASE_URL_XAI=https://api.x.ai/v1
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_BATCH_SIZE=100
EMBEDDING_PROVIDER=local
EMBEDDING_API_BASE_URL=https://api.x.ai/v1
LOCAL_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_VECTOR_SIZE=384
QDRANT_RECREATE_ON_VECTOR_MISMATCH=false
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
UPLOAD_DIR=/tmp/rag_uploads
LOG_LEVEL=INFO
